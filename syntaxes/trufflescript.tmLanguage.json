{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "TruffleScript",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#symbols"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.trufflescript",
					"match": "\\b(if|else|while|for|return|in|of|break|continue|try|catch|throw|require|export|inherits)\\b"
				},
				{
					"name": "storage.modifier.trufflescript",
					"match": "\\b(class|struct|func)\\b|(?<=\\))\\s*\\=\\>"
				},
				{
					"name": "storage.type.trufflescript",
					"match": "\\b(number|string|bool|void)\\b"
				},
				{
					"name": "variable.language.trufflescript",
					"match": "\\b(let|const|(this|super)(?=\\.)|null|new)\\b|\\b(fmt|c)\\b\\s*\\!(?=[\"'])"
				},
				{
					"name": "constant.language.trufflescript",
					"match": "\\b(true|false)\\b"
				},
				{
					"name": "support.class.trufflescript",
					"match": "\\b(map|arr|Int|Float|File|Module)\\b\\s*(?!\\()|\\b(unknown|(?<=File\\.)Handle)\\b|\\b(Error)\\b\\s*(?=\\()"
				},
				{
					"name": "support.function.trufflescript",
					"match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\()\\b"
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.double.trufflescript",
					"begin": "\"",
					"end": "\"",
					"patterns": [
						{
							"name": "constant.character.escape.trufflescript",
							"match": "\\\\(\\\\|\\'|\\\"|\\?|a|b|f|n|r|t|v|0|[0-7]{3}|x[A-Fa-f0-9]{2}|u[A-Fa-f0-9]{4}|U[A-Fa-f0-9]{8})"
						}
					]
				},
				{
					"name": "string.quoted.single.trufflescript",
					"begin": "'",
					"end": "'",
					"patterns": [
						{
							"name": "constant.character.escape.trufflescript",
							"match": "\\\\(\\\\|\\'|\\\"|\\?|a|b|f|n|r|t|v|0|[0-7]{3}|x[A-Fa-f0-9]{2}|u[A-Fa-f0-9]{4}|U[A-Fa-f0-9]{8})"
						}
					]
				},
				{
					"name": "string.quoted.multi.trufflescript",
					"begin": "\"\"\"",
					"end": "\"\"\"",
					"patterns": [
						{
							"name": "constant.character.escape.trufflescript",
							"match": "\\\\(\\\\|\\'|\\\"|\\?|a|b|f|n|r|t|v|0|[0-7]{3}|x[A-Fa-f0-9]{2}|u[A-Fa-f0-9]{4}|U[A-Fa-f0-9]{8})"
						}
					]
				}
			]
		},
		"comments": {
			"patterns": [
				{
					"name": "comment.block.trufflescript",
					"begin": "/\\*",
					"end": "\\*/",
					"patterns": [
						{
							"include": "#comments"
						}
					]
				},
				{
					"name": "comment.double-slash.trufflescript",
					"match": "//.*"
				}
			]
		},
		"symbols": {
			"patterns": [
				{
					"name": "constant.numeric.trufflescript",
					"match": "\\b(\\d+)\\b|\\b0x[0-9A-F]*\\b|\\b[0-9][0-9_]*\\b"
				},
				{
					"name": "punctuation.trufflescript",
					"match": ";\\.:\\?"
				}
			]
		}
	},
	"scopeName": "source.trs"
}
